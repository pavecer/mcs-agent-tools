# Environment — dev mode (two ports)
REFLEX_ENV=dev
FRONTEND_PORT=3000
BACKEND_PORT=8000

# Environment — prod mode (single port; set REFLEX_ENV=prod)
# REFLEX_ENV=prod
# PORT=2009

# Authentication — comma-separated username:password pairs
# Leave empty to disable authentication entirely
# USERS=admin:secret123,analyst:pass456
USERS=admin:CHANGE_ME

# Log level
LOG_LEVEL=INFO
